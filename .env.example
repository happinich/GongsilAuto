# 공실닷컴 로그인 정보
GONGSIL_ID=아이디입력
GONGSIL_PW=비밀번호입력
GONGSIL_PAGE=페이지번호

# 브라우저 표시 여부 (true=숨김, false=보임)
HEADLESS=true

# ── 자주 실행: 아파트/오피스텔 전세·월세·단기 ──────────────────────────
# 실행 시간 (쉼표로 구분, 24시 형식) - 기본: 매일 09~17시 2시간 간격 5회
FREQUENT_TIMES=09:00,11:00,13:00,15:00,17:00
# 1회 실행당 재등록할 매물 수
FREQUENT_MAX=5

# ── 주간 실행: 상가/주택/매매 ────────────────────────────────────────────
# 실행 요일 (mon/tue/wed/thu/fri/sat/sun)
WEEKLY_DAY=mon
# 실행 시간
WEEKLY_TIME=09:00
# 1회 실행당 재등록할 매물 수 (0=전체)
WEEKLY_MAX=0
